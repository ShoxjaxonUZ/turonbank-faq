# OpenRouter API kaliti (majburiy) — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# AI model (ixtiyoriy) — standart: google/gemma-4-31b-it:free
# Boshqa modellar: https://openrouter.ai/models
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# Saytning manzili (ixtiyoriy, OpenRouter reytingi uchun)
OPENROUTER_SITE_URL=https://turon-bank.vercel.app

# ── Standalone backend server (server.js) uchun ──
# Server porti (ixtiyoriy — Railway/Render avtomatik beradi)
PORT=3001

# CORS: ruxsat etilgan frontend domenlari (vergul bilan). Bo'sh = barchasi (*).
CORS_ORIGIN=https://turon-bank.vercel.app
